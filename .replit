modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Draba Mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Draba Web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Draba Mobile"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=22778 BASE_PATH=/draba-mobile/ pnpm --filter @workspace/draba-mobile run dev"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Draba Web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=20344 BASE_PATH=/ pnpm --filter @workspace/draba run dev"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[[ports]]
localPort = 5000
externalPort = 80
